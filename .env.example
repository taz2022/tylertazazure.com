# Copy this file to .env and fill in your values.
# Never commit your real .env to version control.

# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Site
PUBLIC_SITE_URL=https://yourdomain.com
CONTACT_EMAIL=tyler@yourdomain.com

# Backblaze B2
# How to find these values:
#   BACKBLAZE_BUCKET_NAME   → Your bucket name in the B2 console
#   BACKBLAZE_BUCKET_URL    → Public URL for the bucket, e.g.:
#                             https://f005.backblazeb2.com/file/your-bucket-name
#                             (Used for constructing public CDN asset URLs)
#   BACKBLAZE_KEY_ID        → Application Key ID (from B2 App Keys page)
#   BACKBLAZE_APPLICATION_KEY → Application Key secret
#   BACKBLAZE_ENDPOINT      → S3-compatible endpoint for your region, e.g.:
#                             https://s3.us-west-004.backblazeb2.com
#   BACKBLAZE_REGION        → Your bucket's region, e.g.: us-west-004
#
# For display-only (v1), only BACKBLAZE_BUCKET_URL is required.
# The KEY_ID and APPLICATION_KEY are only needed for server-side uploads.

BACKBLAZE_BUCKET_NAME=your-bucket-name
BACKBLAZE_BUCKET_URL=https://f005.backblazeb2.com/file/your-bucket-name
BACKBLAZE_KEY_ID=your-key-id
BACKBLAZE_APPLICATION_KEY=your-application-key
BACKBLAZE_ENDPOINT=https://s3.us-west-004.backblazeb2.com
BACKBLAZE_REGION=us-west-004
